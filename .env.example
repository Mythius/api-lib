# Server
PORT=80
NODE_ENV=development
# The public-facing base URL of this auth server (used to build OAuth callback URLs)
AUTH_BASE_URL=http://localhost:80

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URIs: ${AUTH_BASE_URL}/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Redirect URI: ${AUTH_BASE_URL}/auth/callback/microsoft
# Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
MS_CLIENT_ID=your-ms-app-client-id
MS_CLIENT_SECRET=your-ms-app-client-secret
